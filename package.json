{
  "name": "networth-tracker",
  "description": "A personal net worth tracker built with Nuxt.js",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:report": "npx vite preview --outDir reports/unit",
    "test:report:coverage": "npx vite preview --outDir reports/unit",
    "test:e2e": "playwright test",
    "test:e2e:report": "npx playwright show-report",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nuxt/ui": "^4.4.0",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^4.3.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "tailwindcss": "^4.2.0",
    "vue": "^3.5.28",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@iconify-json/lucide": "^1.2.92",
    "@nuxt/eslint": "^1.15.1",
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "1.56.1",
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "4.0.18",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.1",
    "happy-dom": "^20.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
